{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.mjs"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node .cursor/hooks/quality-after-mcp-execution.mjs"
      },
      {
        "command": "node .cursor/hooks/mark-sequential-thinking.mjs",
        "matcher": "sequentialthinking"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/hooks/quality-before-mcp-execution.mjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/quality-pre-tool-use.mjs"
      },
      {
        "command": "node .cursor/hooks/mark-sequential-thinking.mjs",
        "matcher": "sequentialthinking|sequential-thinking"
      },
      {
        "command": "node .cursor/hooks/require-preflight.mjs",
        "matcher": "Read|Grep|Glob|Shell|Task|Write|StrReplace|Delete|EditNotebook",
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "node .cursor/hooks/quality-post-tool-use.mjs"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/quality-before-shell-execution.mjs"
      }
    ],
    "afterShellExecution": [
      {
        "command": "node .cursor/hooks/quality-after-shell-execution.mjs"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/quality-after-file-edit.mjs"
      }
    ],
    "subagentStart": [
      {
        "command": "node .cursor/hooks/quality-subagent-start.mjs"
      },
      {
        "command": "node .cursor/hooks/require-preflight-subagent.mjs",
        "failClosed": true
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/audit-compliance.mjs",
        "loop_limit": 1
      }
    ]
  }
}
