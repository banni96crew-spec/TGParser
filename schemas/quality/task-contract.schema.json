{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telegram-lead-discovery.local/schemas/quality/task-contract.schema.json",
  "title": "LLM assurance task contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "conversation_id",
    "task_id",
    "profile",
    "allowed_paths",
    "denied_paths",
    "owner_documents",
    "requirement_ids",
    "required_checks",
    "approval"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "read_only",
        "documentation_mutation",
        "product_mutation"
      ]
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "denied_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "owner_documents": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(GOV|[A-Z]{2,5})-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "approved_by"
      ],
      "properties": {
        "status": {
          "enum": [
            "approved",
            "not_required",
            "pending",
            "denied"
          ]
        },
        "approved_by": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "allowed_mcp_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    }
  }
}
