{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telegram-lead-discovery.local/schemas/quality/journal-event.schema.json",
  "title": "LLM assurance journal event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "conversation_id",
    "task_id",
    "event_type",
    "occurred_at",
    "actor",
    "details"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "enum": [
        "policy",
        "tool",
        "edit",
        "check",
        "recovery"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "enum": [
        "local_operator",
        "llm_agent",
        "ci_system"
      ]
    },
    "stable_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "tool": {
          "type": "string"
        },
        "check": {
          "type": "string"
        },
        "verdict": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        },
        "gate": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
