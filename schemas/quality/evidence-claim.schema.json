{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telegram-lead-discovery.local/schemas/quality/evidence-claim.schema.json",
  "title": "LLM assurance evidence claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "claim_id",
    "conversation_id",
    "task_id",
    "requirement_ids",
    "claim",
    "trust",
    "evidence_scope",
    "status",
    "evidence_refs",
    "observed_files",
    "requested_checks",
    "unresolved_failures",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "claim_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:AT-)?(?:GOV|[A-Z]{2,5})-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "trust": {
      "const": "untrusted_local_claim"
    },
    "evidence_scope": {
      "const": "local"
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "not_run",
        "unsupported"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "observed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "requested_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "unresolved_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "base_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40,64}$"
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40,64}$"
    },
    "supersedes_claim_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "evidence_refs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
